% КОНЕЦ § 10
% =============================================================

% =============================================================
% § 11. ДОМАШНЯЯ РАБОТА
% =============================================================
%
% Концепция: «Рабочий лист с достоинством»
%
% Домашняя работа — единственный тип из системы, который ученик
% держит дома, работает с ним в своём темпе, может возвращаться
% к нему. Это не бланк для сдачи, не карточка для среза знаний.
%
% Дизайн-решения:
%
%   ФОРМАТ: A4 portrait — привычная тетрадная ориентация,
%   удобна для работы за столом и хранения в папке.
%
%   ШАПКА: компактная — одна строка с названием и датой сдачи.
%   Нет бейджа варианта, нет оценки. Только класс и имя.
%   Левое поле шире (25 мм) — место для пометок учителя.
%
%   ЗАДАНИЯ: три режима плотности:
%     \hwcalc   — компактный вычислительный блок (как calcrowc)
%     \hwtask   — задание с пространством для записей
%     \hwproblem — задача с явным полем, но без рамки и пунктира:
%                  просто вертикальный левый маркер (тонкая черта)
%                  и строка «Ответ:» внизу. Выглядит как тетрадь,
%                  а не как бланк.
%
%   ПОДСКАЗКИ: опциональный блок \hwhint{текст} —
%   лёгкий серый текст-напоминание (формула, правило).
%   Печатается только если учитель хочет.
%
%   НИЖНИЙ КОЛОНТИТУЛ: тонкая строка с датой сдачи и
%   местом для подписи учителя — лаконично.
%
% Отличия от других типов:
%   Пятиминутка — жёсткий хронометраж, нет места для записей
%   Самостоятельная — в классе, два варианта, официально
%   Контрольная — строго, бланк, поля для оценки
%   Домашняя — свободнее, личная работа, место для мысли
%
% =============================================================

% =============================================================
% § 11.1  ГЕОМЕТРИЯ ДОМАШНЕЙ РАБОТЫ
%
% Portrait A4, левое поле 25 мм (для пометок учителя),
% правое 15 мм, верх/низ 18 мм.
% =============================================================
\newcommand{\hwsetgeometry}{%
  \newgeometry{%
    left   = 25mm,
    right  = 15mm,
    top    = 18mm,
    bottom = 18mm,
    noheadfoot
  }%
}

% Ширина рабочей зоны: 210 - 25 - 15 = 170 мм
\newlength{\hwtextwidth}
\setlength{\hwtextwidth}{170mm}

% =============================================================
% § 11.2  ШАПКА ДОМАШНЕЙ РАБОТЫ
%
% \hwheader{класс}{тема}{дата сдачи}
%
% Макет:
%   Домашняя работа                    Класс: ___
%   Тема: ____________________________
%   Имя и фамилия: ___________________  Сдать до: ___
%   ─────────────────────────────────── (тонкая черта)
%
% Принципы:
%   • Нет акцентных чёрных черт сверху — домашняя мягче контрольной
%   • Только одна разделительная черта снизу шапки
%   • «Сдать до:» вместо «Дата:» — акцент на личной ответственности
%   • Нет поля «Оценка» — оценка не главная цель домашней работы
% =============================================================
\newcommand{\hwheader}[3]{%
  % --- Строка 1: название + класс ---
  \noindent
  {\fontsize{12}{14}\bfseries\selectfont Домашняя работа}%
  \hfill
  {\fontsize{8.5}{10}\selectfont Класс:\enspace}%
  \rule{18mm}{0.32pt}%
  \par\vspace{2mm}%
  % --- Строка 2: тема ---
  {\fontsize{8.5}{10.5}\selectfont\color{mw@mid}%
   Тема:\enspace}%
  {\fontsize{8.5}{10.5}\itshape\selectfont #2}%
  \par\vspace{3.5mm}%
  % --- Строка 3: имя + дата сдачи ---
  \noindent
  {\fontsize{8.5}{10}\selectfont Имя и фамилия:\enspace}%
  \hrulefill
  \hspace{5mm}%
  {\fontsize{8}{9.5}\selectfont Сдать до:\enspace}%
  {\fontsize{8}{9.5}\bfseries\selectfont #3}%
  \par\vspace{3.5mm}%
  % --- Разделитель ---
  {\color{mw@rule}\hrule height 0.45pt}%
  \vspace{5mm}%
}

% =============================================================
% § 11.3  ТЕМАТИЧЕСКИЙ БЛОК (необязательный)
%
% \hwsection{название}
%
% Для структурирования длинной домашней работы:
% «Упражнения», «Задачи», «Дополнительно» и т.п.
% Мягче, чем \ctsection: нет черты под заголовком,
% только небольшой отступ и курсив.
% =============================================================
\newcommand{\hwsection}[1]{%
  \par\vspace{5mm}%
  \noindent
  {\fontsize{8.5}{10}\bfseries\itshape\selectfont\color{mw@mid} #1}%
  \par\vspace{2mm}%
}

% =============================================================
% § 11.4  ЗАДАНИЯ ДОМАШНЕЙ РАБОТЫ
% =============================================================

% ---- Вычислительное задание ---------------------------------
% \hwcalc{номер}{выражение}
% Идентичен calcrowc, но с чуть большей линией ответа (30 мм)
% и шрифтом 9pt — чуть просторнее для домашней работы.
\newcommand{\hwcalc}[2]{%
  \noindent\begin{tabular}{@{}%
    r@{\hspace{4pt}}l@{\hspace{6pt}}r@{\hspace{5pt}}l@{}}
    {\color{mw@mid}\fontsize{8}{9.5}\selectfont #1.} &
    $\textstyle #2$ & {$=$} & \rule{30mm}{0.35pt}
  \end{tabular}\par\vspace{2.5mm}%
}

% ---- Обычное задание ----------------------------------------
% \hwtask{номер}{текст}
% Задание с текстом и местом для записей под ним.
% Отступ 15 мм под задачей — ученик пишет прямо на листе.
\newcommand{\hwtask}[2]{%
  \noindent\begin{tabular}{@{}r@{\hspace{4pt}}p{\mw@taskwid}@{}}
    {\color{mw@mid}\fontsize{8}{10}\selectfont #1.} &
    {\fontsize{9}{12}\selectfont #2}
  \end{tabular}%
  \par\vspace{13mm}%
}

% ---- Задание с явными строками для ответа -------------------
% \hwtasklines{номер}{текст}{кол-во строк}
% Под текстом задания — N тонких линий для записи решения.
\newcommand{\hwtasklines}[3]{%
  \noindent
  {\color{mw@mid}\fontsize{8}{10}\selectfont #1.}\enspace
  {\fontsize{9}{12}\selectfont\parbox[t]{\mw@taskwid}{#2}}\par
  \vspace{2mm}%
  \mw@hwlines{#3}{150}%
  \vspace{3mm}%
}

% Вспомогательная команда: N строк для записи решения
% Стиль: тонкие линии без рамки и пунктира — как в тетради
\newcommand{\mw@hwlines}[2]{%
  % #1 = кол-во строк, #2 = ширина в мм (числовое значение)
  \par\noindent
  \begin{tikzpicture}
    \pgfmathsetmacro{\nlines}{#1}
    \pgfmathsetmacro{\lineht}{7}
    \pgfmathsetmacro{\totalht}{\nlines * \lineht}
    \pgfmathsetmacro{\linewid}{#2}
    \draw[mw@light, line width=0.6pt]
      (0, 0) -- (0, \totalht mm);
    \foreach \i in {1,...,#1}{%
      \draw[mw@hairline, line width=0.3pt]
        (3mm, \i*\lineht mm) -- (\linewid mm, \i*\lineht mm);
    }
    \draw[mw@hairline, line width=0.3pt]
      (3mm, 0) -- (\linewid mm, 0);
  \end{tikzpicture}\par%
}

% ---- Задача с полем для решения и строкой ответа ------------
% \hwproblem{номер}{условие}{кол-во строк}
%
% Отличие от ctproblem и taskproblem:
%   • Нет рамки вокруг поля — не «бланк», а «место для работы»
%   • Левый вертикальный маркер — визуально отделяет поле,
%     не давя на ученика рамкой
%   • «Ответ:» — отдельная строка под полем, не внутри него
%   • Между условием и полем — небольшой воздух
\newcommand{\hwproblem}[3]{%
  % Номер + условие без tabular — чтобы избежать Overfull в long text
  \noindent
  {\color{mw@mid}\fontsize{8}{10}\selectfont #1.}\enspace
  {\fontsize{9}{12}\selectfont\parbox[t]{\mw@taskwid}{#2}}%
  \par\vspace{3mm}%
  \mw@hwlines{#3}{150}%
  \par\vspace{2mm}%
  % Строка ответа — явный \par гарантирует новую строку после tikz
  \noindent
  {\fontsize{8}{10}\selectfont\color{mw@mid} Ответ:\enspace}%
  \rule{45mm}{0.32pt}%
  \par\vspace{4mm}%
}

% =============================================================
% § 11.5  БЛОК-ПОДСКАЗКА
%
% \hwhint{текст}
%
% Лёгкий серый текст с иконкой — напоминание о формуле
% или правиле. Учитель включает его по необходимости.
% Визуально: маленький ромб-маркер + курсивный серый текст.
% =============================================================
\newcommand{\hwhint}[1]{%
  \par\vspace{1mm}%
  \noindent
  % Маленький ромб-маркер через \rule и inline TikZ без baseline anchor
  \begin{tikzpicture}[baseline=0.4ex]
    \fill[mw@light] (0, 0.5ex)
      -- (0.85ex, 1.1ex) -- (1.7ex, 0.5ex) -- (0.85ex, -0.1ex) -- cycle;
  \end{tikzpicture}%
  \hspace{3pt}%
  {\fontsize{7.5}{9.5}\itshape\selectfont\color{mw@rule} #1}%
  \par\vspace{2mm}%
}

% =============================================================
% § 11.6  НИЖНИЙ КОЛОНТИТУЛ ДОМАШНЕЙ РАБОТЫ
%
% \hwfooter
%
% Тонкая нижняя строка: место для подписи учителя.
% Вставляется перед \end{document} через \vfill\hwfooter.
% =============================================================
\newcommand{\hwfooter}{%
  {\color{mw@rule}\hrule height 0.35pt}%
  \vspace{2mm}%
  \noindent
  {\fontsize{7}{8.5}\selectfont\color{mw@mid}%
   Проверил:\enspace\rule{40mm}{0.28pt}%
   \hfill
   Подпись:\enspace\rule{30mm}{0.28pt}%
  }%
  \par
}

